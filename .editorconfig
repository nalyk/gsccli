# https://editorconfig.org
# Mirrors biome.json so editors without a Biome plugin still produce conforming files.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 110

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2

[pnpm-lock.yaml]
trim_trailing_whitespace = false
insert_final_newline = false
