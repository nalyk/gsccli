# Path to Google service account credentials JSON file (optional if using OAuth)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Default Search Console site URL (optional — overrides project + global config files)
# Examples: https://example.com/   or   sc-domain:example.com
GSC_SITE_URL=https://example.com/

# Override the global config dir (default: ~/.gsccli). Useful for isolating two
# parallel agents or for sandboxed CI runs. Project-local .gsccli.json files are
# discovered independently by walking up from CWD; this only affects the global file.
# GSCCLI_CONFIG_DIR=/path/to/alt/global/dir
